/*3. Create a class Employee with overloaded constructors to initialize employee details
 based on different combinations of arguments. Ensure the constructors support the creation of objects
 in various ways.*/

class Employee {
	private int age;
	private String position;
	private String name;
	private String department;
	
	

	public String getName() {
		return name;
	}

	public int getAge() {
		return age;
	}

	public String getPosition() {
		return position;
	}
		
	public String getDepartment()  {
		return department;
	}

	public void PrintInfo() {
		System.out.println("New Employee's name is " + e1.getName());
                System.out.println("His age is " + e1.getAge());
                System.out.println("His position is " + e1.getPosition());
                System.out.println("He works in a " + e1.getDepartment() + " Department");
        }
                
        public void setDepartment(String depart) {
                department = depart;
       
}

public class OOPsolution3 {
        public static void main(String[] args) {
                Employee e1 = new Employee();
        
                e1.setName("Yeraly");
                e1.setAge(20);
                e1.setPosition("Backend-Devolper");
                e1.setDepartment("IT");
		
		e1.printInfo()
      
	}
} 
      

