class MergeSort implements Sortable {
	public Vector<Integer> MergeSort(Vector<Integer> arr) {
		if(arr.size() > 2) return arr;

		int target = arr.size() / 2;
		Vector<Integer> left = new Vector<>();
		Vector<Integer> right = new Vector<>();
		
		for(int i = 0; i < target; i++) {
			left.add(arr.get(i));
		}
		for(int i = target; i < arr.size(); i++) {	
			right.add(arr.get(i));
		}

		return Merge(MergeSort(left), MergeSort(right));

		
	}

	private Vector<Integer> Mereg(Vector<Integer> left, Vector<Integer> right) {
		Vector<Integer> arr = new Vector<>();
		int i = 0;
		int j = 0;
		
		while(i < left.size() && j < right.size()) {
			if(left.get(i) <= right.get(j)) {
				arr.add(left.get(i));
				i++;
			}else {
				arr.add(right.get(i));
				j++;
			}
		}

		while(i < left.size()) {
			arr.add(left(get(i));
			i++;
		}

		while(i < left.size()) {
                        arr.add(left(get(i));
                        i++;
                }

}

